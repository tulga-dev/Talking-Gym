# --- Required ---
TELEGRAM_BOT_TOKEN=123456:ABC-your-botfather-token
XAI_API_KEY=xai-your-key

# --- LLM (OpenAI-compatible; defaults to xAI Grok) ---
LLM_BASE_URL=https://api.x.ai/v1
LLM_MODEL=grok-4.3

# --- Voice ---
STT_MODEL=grok-stt
STT_LANGUAGE=en
TTS_ENABLED=true
TTS_VOICE=ara            # eve | ara | rex | sal | leo

# --- Cost guardrails ---
DAILY_VOICE_SECONDS_CAP=300   # max seconds of learner audio per user per day

# --- Coaching ---
TIMEZONE=Asia/Ulaanbaatar
DEFAULT_REMINDER_HOUR=19      # daily nudge, local time (0-23)
TURNS_PER_SESSION=3           # user voice turns per daily session

# --- Storage ---
# Production: Supabase Postgres — Dashboard > Connect > "Transaction pooler" URI (port 6543).
# Tables are auto-created on first boot. Leave empty to use local SQLite (dev only —
# data is lost on redeploy).
SUPABASE_DB_URL=
DB_PATH=talking_gym.db

# --- Operations ---
# Your own Telegram numeric id (ask @userinfobot): receives /feedback, can run /stats.
ADMIN_CHAT_ID=

# --- Facebook Messenger channel (optional) ---
# From developers.facebook.com: create an app -> add Messenger product ->
# connect your Facebook Page -> generate a Page access token.
# Webhook URL: https://talking-gym-mn.fly.dev/webhooks/messenger
# Subscribe to: messages, messaging_postbacks. Verify token = the value below.
MESSENGER_PAGE_TOKEN=
MESSENGER_VERIFY_TOKEN=talking-gym-verify
MESSENGER_APP_SECRET=
PORT=8080
