{
  "appId": "mn.talkinggym.app",
  "appName": "Talking Gym",
  "webDir": "www",
  "server": {
    "url": "https://talking-gym-mn.fly.dev/app",
    "allowNavigation": [
      "talking-gym-mn.fly.dev",
      "accounts.google.com",
      "*.googleusercontent.com"
    ]
  },
  "ios": {
    "contentInset": "never",
    "backgroundColor": "#F6FBF0",
    "scrollEnabled": true
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": false,
      "backgroundColor": "#33A62C",
      "showSpinner": false,
      "iosSpinnerStyle": "large"
    },
    "Keyboard": {
      "resize": "native"
    }
  }
}
